{
  "name": "postbase-users-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "",
  "main": "user-server.mjs",
  "scripts": {
    "start": "NODE_ENV=production dotenvx run -f .env.production --  bun  ./dist/app.mjs",
    "dev": "NODE_ENV=development dotenvx run -f .env.development --  bun  ./src/app.mjs",
    "drizzlekit-prod": "NODE_ENV=production dotenvx run -f .env.production  -- bun drizzle-kit",
    "drizzlekit-dev": "dotenvx run -f .env.development -- bun drizzle-kit",
    "app": "dotenvx run -f .env.development -- bun ./src/app.mjs",
    "build": "tsc",
    "test": "dotenvx run -f .env.development -- bun test --watch"
  },
  "author": "Usman Ghani",
  "license": "",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^1.0.0-rc.4",
    "hono": "^4.12.28",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.0",
    "drizzle-kit": "^1.0.0-rc.4",
    "typescript": "^5.9.3"
  }
}
