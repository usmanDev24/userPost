{
  "name": "postbase-users-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "",
  "main": "user-server.mjs",
  "scripts": {
    
    "start": "NODE_ENV=production dotenvx run -f .env.production --  bun  ./dist/app.mjs",
    "dev": "NODE_ENV=development dotenvx run -f .env.development --  bun  ./src/app.mjs",
    "prisma-pro": "NODE_ENV=production dotenvx run -f .env.production  -- bunx --bun prisma --config=./src/prisma.config.ts",
    "prisma-dev": "dotenvx run -f .env.development -- bunx  --bun prisma --config=./src/prisma.config.ts",
    "app": "dotenvx run -f .env.development -- bun ./src/app.mjs",
    "build": "bunx --bun  prisma --config=./src/prisma.config.ts generate  && tsc",
    "test": "dotenvx run -f .env.development -- bun test --watch"
  },
  "author": "Usman Ghani",
  "license": "",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.28",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3"
  }
}
