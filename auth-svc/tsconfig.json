{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node", "bun"],

    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,

    "allowJs": true,
    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }, 
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "tests/**/*",
    "src/public/**/*"
  ]
}